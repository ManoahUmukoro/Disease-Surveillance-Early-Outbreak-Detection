# ── MongoDB ──────────────────────────────────────────────
# Local for development; swap to your MongoDB Atlas SRV string for deployment.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=disease_surveillance

# ── FastAPI backend ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated origins allowed by CORS (add the deployed frontend URL here).
CORS_ORIGINS=http://localhost:5173

# ── Frontend (Vite) ──────────────────────────────────────
# Base URL the React app calls; set to the deployed backend URL in production.
VITE_API_BASE_URL=http://localhost:8000
