backend/models/*.pkl
backend/models/*.keras

# ── Node / frontend ──────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/

# ── OS ───────────────────────────────────────────────────
.DS_Store

# ── Editor / tooling ─────────────────────────────────────
.claude/

# ── Adaptive SVM runtime artifacts (not source) ──────────
adaptive-svm/data/surveillance.db
~$*
