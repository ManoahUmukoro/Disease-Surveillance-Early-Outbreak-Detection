# Copy to .env for local runs, or set these as Secrets on Streamlit Community Cloud.
# ALL are OPTIONAL — the app degrades gracefully to SQLite-only when they are unset.

# MongoDB — the unstructured store (clinical notes, lab info, uploaded documents).
# Docker Compose sets this automatically to the bundled mongo service. For the DEPLOYED
# Streamlit app, reuse your MongoDB Atlas cluster:
#   MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Redis Streams — the ingestion bus. Docker Compose sets this to the bundled redis service.
# For a live hosted demo you can use a free serverless Redis (e.g. Upstash) URL.
REDIS_URL=

# SMTP (optional) — turns the alert layer into real e-mail. Without it, alerts log to the
# dashboard (method = Dashboard) instead of being sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@surveillance.local
